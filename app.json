{
  "expo": {
    "name": "super-looi-app",
    "slug": "super-looi-app",
    "version": "1.0.0",
    "orientation": "landscape",
    "icon": "./assets/images/icon.png",
    "scheme": "superlooiapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.superlooiapp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.superlooiapp"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Looi to record voice commands",
          "recordAudioAndroid": true,
          "enableBackgroundRecording": false
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Allow Looi to read calendars for upcoming reminder checks",
          "remindersPermission": "Allow Looi to read reminders for upcoming reminder checks"
        }
      ],
      "@siteed/sherpa-onnx.rn/app.plugin",
      [
        "@siteed/audio-studio",
        {
          "enablePhoneStateHandling": false,
          "enableNotifications": false,
          "enableBackgroundAudio": false,
          "enableDeviceDetection": false,
          "iosConfig": {
            "microphoneUsageDescription": "Allow Looi to listen for the wake word and voice commands"
          }
        }
      ],
      "./plugins/with-android-audio-studio-excluded",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
